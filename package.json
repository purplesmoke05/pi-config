{
  "name": "@purplesmoke05/pi-config",
  "version": "0.1.0",
  "description": "Personal pi coding agent customizations: extensions, prompt templates, and reviewed provider integrations",
  "keywords": [
    "pi-package"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/purplesmoke05/pi-config"
